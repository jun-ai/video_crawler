# ==================== 数据库配置 ====================
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/english_learning

# ==================== JWT配置 ====================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== 存储配置 ====================
# 存储类型: local, aliyun_oss, tencent_cos
STORAGE_TYPE=local

# 本地存储配置（开发环境）
UPLOAD_DIR=../data/materials
MEDIA_BASE_URL=/static

# ---- 阿里云OSS配置（生产环境推荐）----
# ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
# ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# ALIYUN_OSS_BUCKET_NAME=english-learning-media
# ALIYUN_OSS_URL_EXPIRE=3600

# ---- 腾讯云COS配置 ----
# TENCENT_COS_SECRET_ID=your-secret-id
# TENCENT_COS_SECRET_KEY=your-secret-key
# TENCENT_COS_REGION=ap-shanghai
# TENCENT_COS_BUCKET_NAME=english-learning-1234567890

# CDN域名（可选，配置后文件访问将使用CDN加速）
# CDN_DOMAIN=cdn.yourdomain.com

# 视频流基础URL（生产环境使用 CDN 或域名，替代 localhost）
# VIDEO_BASE_URL=https://cdn.yourdomain.com

# ==================== AI API配置 ====================
# 多 provider fallback,按优先级:deepseek → glm → minimax
# 没配 key 的 provider 自动跳过;401/402/429/5xx 触发后自动切下一个
# 协议支持:OpenAI 兼容(DeepSeek)、Anthropic 兼容(智谱 GLM anthropic、MiniMax anthropic)

# DeepSeek — OpenAI 兼容协议 (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_d...here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 智谱 GLM — Anthropic 兼容协议 (https://open.bigmodel.cn/api/anthropic)
GLM_API_KEY=your_g...key
GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
GLM_MODEL=glm-4.5

# 月之暗面 MiniMax — Anthropic 兼容协议 (https://api.minimaxi.com/anthropic)
# ccswitch 的 sk-cp- 前缀 key 需走 ccswitch 代理才能用,留空则跳过
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M3

# 讯飞语音识别 API
# XUNFEI_APP_ID=your-app-id
# XUNFEI_API_KEY=your-api-key
# XUNFEI_API_SECRET=your-api-secret

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS 配置：允许的域名，逗号分隔。开发环境用 * 允许全部
# 生产环境示例：CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=*
