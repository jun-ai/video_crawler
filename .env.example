# ============================================
# 英语学习平台 - 环境变量模板
# ============================================
# 复制此文件为 .env 并填入实际值
# 已添加到 .gitignore，请勿提交包含真实密钥的 .env 文件

# ============================================
# 1. 数据库配置
# ============================================
# MySQL root 密码
MYSQL_ROOT_PASSWORD=change-me-in-production

# 直接使用 MYSQL_ROOT_PASSWORD，docker-compose 会自动拼接
# DATABASE_URL=mysql+aiomysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/english_learning

# ============================================
# 2. JWT 安全配置
# ============================================
# 生产环境请使用至少 32 位的随机字符串
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# 3. 存储配置
# ============================================
# 存储类型: local, aliyun_oss, tencent_cos
STORAGE_TYPE=aliyun_oss

# ---- 阿里云 OSS ----
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET_NAME=english-learning-media
ALIYUN_OSS_URL_EXPIRE=3600

# ---- 腾讯云 COS ----
# TENCENT_COS_SECRET_ID=your-secret-id
# TENCENT_COS_SECRET_KEY=your-secret-key
# TENCENT_COS_REGION=ap-shanghai
# TENCENT_COS_BUCKET_NAME=english-learning-1234567890

# CDN 域名（用于加速访问，可选）
CDN_DOMAIN=cdn.yourdomain.com

# 本地存储（开发环境使用，生产环境可忽略）
UPLOAD_DIR=./data/materials
MEDIA_BASE_URL=/static

# ============================================
# 4. 视频流配置
# ============================================
# 生产环境视频访问的基础 URL
# 如果使用 CDN：设置为 https://cdn.yourdomain.com
# 如果使用 nginx 反向代理：留空
VIDEO_BASE_URL=https://cdn.yourdomain.com

# ============================================
# 5. AI API 配置
# ============================================
# DeepSeek（用于生成解读、翻译、发音评测）
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 讯飞语音识别（发音评测）
XUNFEI_APP_ID=your-app-id
XUNFEI_API_KEY=your-api-key
XUNFEI_API_SECRET=your-api-secret

# ============================================
# 6. 服务配置
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS 配置（生产环境应配置具体域名，逗号分隔）
# 示例：CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com